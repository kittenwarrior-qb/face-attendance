# --- App ---
LOG_LEVEL=INFO

# --- Postgres (used by the db service in docker-compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=face_attendance

# --- Database URL used by the FastAPI app (host must match the compose service name: db) ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/face_attendance

# --- InsightFace ---
INSIGHTFACE_MODEL_PACK=buffalo_l
INSIGHTFACE_DET_SIZE=640
INSIGHTFACE_CTX_ID=-1
FACE_MATCH_THRESHOLD=0.5

# --- Image storage ---
STORE_ORIGINAL_IMAGE=true
IMAGE_STORAGE_DIR=/app/storage/faces

# --- Security ---
# Required as X-API-Key header on POST /register. MUST be set to a long random
# value before exposing this service publicly - otherwise anyone can enroll a
# face under any employee_id. Generate one with: openssl rand -hex 32
REGISTER_API_KEY=

# --- Odoo ---
ODOO_URL=http://odoo:8069
ODOO_DB=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=admin
ODOO_ATTACH_IMAGE=false
ODOO_TIMEOUT=10
