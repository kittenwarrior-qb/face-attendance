# --- App ---
LOG_LEVEL=INFO

# --- InsightFace ---
INSIGHTFACE_MODEL_PACK=buffalo_l
INSIGHTFACE_DET_SIZE=640
INSIGHTFACE_CTX_ID=-1
FACE_MATCH_THRESHOLD=0.5

# --- Storage ---
# No local database - embeddings + photos are stored directly in Odoo.
# This only controls whether the registration photo is also pushed to the
# employee's Odoo photo field (hr.employee.image_1920).
STORE_ORIGINAL_IMAGE=true

# --- Security ---
# Required as X-API-Key header on POST /register. MUST be set to a long random
# value before exposing this service publicly - otherwise anyone can enroll a
# face under any employee_id. Generate one with: openssl rand -hex 32
REGISTER_API_KEY=

# Comma-separated origins allowed to call this API from browser JS (e.g. the
# Odoo domain hosting the face-capture widget). Leave empty unless embedding
# this API's /verify into another site's frontend.
CORS_ALLOWED_ORIGINS=

# --- Odoo ---
ODOO_URL=http://odoo:8069
ODOO_DB=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=admin
ODOO_ATTACH_IMAGE=false
ODOO_TIMEOUT=10
